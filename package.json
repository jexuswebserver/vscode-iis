{
  "name": "iis",
  "displayName": "IIS and IIS Express extension for Visual Studio Code",
  "description": "IIS and IIS Express extension for Visual Studio Code. Quickly launch your project in Jexus Manager so that you can run it with local IIS and/or IIS Express.",
  "version": "1.0.16",
  "publisher": "lextudio",
  "os": [
    "win32"
  ],
  "engines": {
    "vscode": "^1.98.0"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "homepage": "https://docs.jexusmanager.com/getting-started/vscode.html",
  "categories": [
    "Other",
    "Testing",
    "Education"
  ],
  "keywords": [
    "IIS",
    "IIS Express",
    "Web Server",
    "Server",
    "Live Server",
    "Dev Server"
  ],
  "icon": "images/iis-icon.png",
  "galleryBanner": {
    "color": "#007acc",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jexuswebserver/vscode-iis.git"
  },
  "bugs": "https://github.com/jexuswebserver/vscode-iis/issues",
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "iis-config",
        "extensions": [
          ".config"
        ],
        "aliases": [
          "IIS Configuration File",
          "IIS Express Configuration File"
        ]
      }
    ],
    "grammars": [
      {
        "language": "iis-config",
        "scopeName": "text.xml",
        "path": "./syntaxes/iis-config.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "iis.launch",
        "title": "Launch IIS/IIS Express from here",
        "category": "IIS/IIS Express",
        "enablement": "iis.supported"
      },
      {
        "command": "iis.resetStatus",
        "title": "Reset IIS/IIS Express selected config file",
        "category": "IIS/IIS Express",
        "enablement": "iis.supported"
      },
      {
        "command": "iis.syncStatus",
        "title": "Sync IIS/IIS Express selected config file when active folder changed",
        "category": "IIS/IIS Express",
        "enablement": "iis.supported"
      },
      {
        "command": "iis.resetFolder",
        "title": "Reset active folder",
        "category": "IIS/IIS Express",
        "enablement": "iis.supported"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "iis.launch",
          "when": "iis.supported"
        },
        {
          "command": "iis.resetStatus",
          "when": "iis.supported"
        },
        {
          "command": "iis.syncStatus",
          "when": "false"
        },
        {
          "command": "iis.resetFolder",
          "when": "iis.supported"
        }
      ],
      "explorer/context": [
        {
          "command": "iis.launch",
          "group": "IIS",
          "when": "iis.supported"
        },
        {
          "command": "iis.resetStatus",
          "group": "IIS",
          "when": "iis.supported"
        },
        {
          "command": "iis.resetFolder",
          "group": "IIS",
          "when": "iis.supported"
        }
      ]
    },
    "configuration": [
      {
        "title": "IIS",
        "properties": {
          "iis.configDir": {
            "type": "string",
            "default": "",
            "description": "The folder that contains the selected config file. Leave it empty to use a temp folder with a default config file.",
            "scope": "resource"
          },
          "iis.browser": {
            "type": "string",
            "default": "",
            "description": "The browser to open web pages. Typical values are \"chrome\", \"firefox\", \"msedge\", \"opera\". Leave it empty to use the default browser.",
            "scope": "resource"
          },
          "iis.activeFolder": {
            "type": "string",
            "default": "",
            "description": "The folder that shows the selected config file in status bar. Leave it empty to use the first folder in the workspace.",
            "scope": "window"
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js --sourcemap --watch",
    "package": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js --sourcemap=external --minify",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext .ts",
    "test": "node ./out/test/runTest.js",
    "dist": "npm ci && vsce package --allow-star-activation",
    "package:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./dist.windows.ps1",
    "package:publish:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./dist.windows.ps1 -Publish",
    "publish:marketplace": "powershell -NoProfile -ExecutionPolicy Bypass -File ./publish.ps1",
    "version:git": "powershell -NoProfile -ExecutionPolicy Bypass -File ./update-version.ps1",
    "version:gitversion": "powershell -NoProfile -ExecutionPolicy Bypass -File ./update-version.ps1",
    "clean": "node -e \"const fs=require('fs');for (const dir of ['dist','out']) fs.rmSync(dir,{recursive:true,force:true});\"",
    "fix": "eslint src --ext .ts --fix",
    "prepare": "npm run compile",
    "posttest": "npm run lint"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@types/vscode": "^1.98.0",
    "@types/xml2js": "^0.4.14",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "xml2js": "^0.6.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint && npm run fix"
    }
  }
}
